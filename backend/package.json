{
  "name": "catalogo-ventas-backend",
  "version": "1.0.0",
  "description": "Backend para catalogo, ventas e inventario con Express, SQLite, Sequelize y Socket.io.",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "build:frontend": "npm --prefix ../frontend run build",
    "start:static": "npm run build:frontend && node server.js",
    "reset-db": "node scripts/reset-database.js",
    "seed": "node scripts/seed.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "sequelize": "^6.37.5",
    "socket.io": "^4.8.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
